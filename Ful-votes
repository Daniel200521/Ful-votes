        function loadData() {
            const saved = localStorage.getItem('ful_vote_final');
            if (saved) {
                const data = JSON.parse(saved);
                DB.users = data.users || DB.users;
                DB.elections = data.elections || DB.elections;
                DB.departmentVotes = data.departmentVotes || DB.departmentVotes;
                if (data.currentUser) { currentUser = data.currentUser; showScreen('dashboardScreen'); loadDashboard(); }
            }
        }

        function save() {
            localStorage.setItem('ful_vote_final', JSON.stringify({ users: DB.users, elections: DB.elections, departmentVotes: DB.departmentVotes, currentUser: currentUser }));
        }

        function showScreen(id) {
            document.querySelectorAll('.screen').forEach(s => s.classList.remove('active'));
            document.getElementById(id).classList.add('active');
            const bottomNav = document.getElementById('bottomNav');
            if (currentUser && ['dashboardScreen','votingScreen','resultsScreen'].includes(id)) {
                bottomNav.style.display = 'flex';
                document.querySelectorAll('.nav-item').forEach(n => n.classList.remove('active'));
                if (id === 'dashboardScreen') document.querySelectorAll('.nav-item')[0].classList.add('active');
                if (id === 'resultsScreen') document.querySelectorAll('.nav-item')[1].classList.add('active');
            } else { bottomNav.style.display = 'none'; }
            if (id === 'dashboardScreen') { loadDashboard(); checkLocation('locationStatusDash'); startLiveUpdates(); }
            if (id === 'votingScreen') checkLocation('locationStatusVote');
            if (id === 'resultsScreen') { showResults(); startLiveUpdates(); }
            if (id === 'loginScreen') stopLiveUpdates();
            clearMessages();
        }

        function clearMessages() {
            const msgs = ['loginMsg','regMsg','otpMsg','voteMsg'];
            msgs.forEach(id => { const el = document.getElementById(id); if (el) el.innerHTML = ''; });
        }

        function validateMatric(matric) {
            return /^[A-Z]{3}\d{2}[A-Z]{3}\d{3}$/.test(matric.toUpperCase());
        }

        function setupMatricInput(inputId) {
            const input = document.getElementById(inputId);
            if (!input) return;
            input.addEventListener('input', function() {
                const pos = this.selectionStart;
                this.value = this.value.toUpperCase();
                this.setSelectionRange(pos, pos);
            });
        }

